<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="450dp"
    android:layout_height="wrap_content"
    android:orientation="vertical" >

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@android:color/darker_gray"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textTeamNumber"
            android:gravity="end|center"
            android:paddingEnd="10dp"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:text="Team Number:"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editTeamNumber"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:background="@color/light_grey"
            android:paddingStart="5dp"
            android:inputType="number" />
    </LinearLayout>

    <TextView
        android:id="@+id/textTeamName"
        android:layout_width="match_parent"
        android:layout_height="23dp"
        android:textSize="16sp"
        android:gravity="center_vertical"
        android:layout_marginStart="150dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textAlliance"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:paddingEnd="10dp"
            android:gravity="end|center"
            android:text="Alliance:"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="20sp" />

        <RadioGroup
            android:id="@+id/radiogroup_Alliance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radiobutton_Blue"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Blue"
                android:textSize="20sp" />

            <RadioButton
                android:id="@+id/radiobutton_Red"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Red"
                android:textSize="20sp"/>
        </RadioGroup>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"/>
</LinearLayout>